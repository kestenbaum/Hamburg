{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-alert": "error",
    "no-var": "error",
    "prefer-const": "error",
    "import/prefer-default-export": "off",
    "max-len": ["error", { "code": 100 }],
    "no-unused-vars": ["warn"]
  }
}
